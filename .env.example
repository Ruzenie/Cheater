# ============================================================
# 多模型 Provider 配置
# 复制为 .env 后填入真实值
# ============================================================

# --- Tier 1: executor (低成本、快速、模板化任务) ---
EXECUTOR_API_KEY=your_executor_api_key
EXECUTOR_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
EXECUTOR_MODEL=doubao-lite-32k

# --- Tier 2: worker (平衡性价比、主力工作) ---
WORKER_API_KEY=your_worker_api_key
WORKER_BASE_URL=https://api.deepseek.com/v1
WORKER_MODEL=deepseek-chat

# --- Tier 3: reasoner (强推理、复杂决策) ---
REASONER_API_KEY=your_reasoner_api_key
REASONER_BASE_URL=https://api.deepseek.com/v1
REASONER_MODEL=deepseek-reasoner

# --- 可选：统一使用同一个 Provider ---
# 如果三个 Tier 用同一个服务，只填这组即可
# LLM_API_KEY=your_api_key
# LLM_BASE_URL=https://api.deepseek.com/v1
